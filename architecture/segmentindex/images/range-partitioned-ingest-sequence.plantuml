@startuml
skinparam shadowing false

actor User
participant "WAL (optional)" as W
participant "WriteRouteMap" as WR
participant "Stable Segment" as S
participant "Segment Write Cache" as C
participant "Background Maintenance" as F

User -> W : append logical op
User -> WR : resolve route
WR -> S : locate segment
S -> C : put(key, value)
S --> User : OK

... later ...

F -> S : flush / compact
S -> C : freeze snapshot
F --> S : publish durable files

alt split scheduled for route
  WR -> WR : short exclusive publish
  WR --> User : stale route retries internally
end

@enduml
