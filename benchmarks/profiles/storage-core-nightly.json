{
  "profile": "storage-core-nightly",
  "description": "Longer canonical storage benchmark set for trend tracking on main/nightly runs.",
  "benchmarks": [
    {
      "label": "sorted-data-diff-key-read-compact",
      "include": "org.hestiastore.benchmark.sorteddatafile.DiffKeyReaderBenchmark",
      "args": [
        "-wi", "2",
        "-i", "5",
        "-f", "1",
        "-r", "2s",
        "-w", "2s",
        "-p", "entryCount=1024",
        "-p", "keyLength=24",
        "-p", "valueLength=16"
      ]
    },
    {
      "label": "sorted-data-diff-key-read-large",
      "include": "org.hestiastore.benchmark.sorteddatafile.DiffKeyReaderBenchmark",
      "args": [
        "-wi", "2",
        "-i", "5",
        "-f", "1",
        "-r", "2s",
        "-w", "2s",
        "-p", "entryCount=8192",
        "-p", "keyLength=48",
        "-p", "valueLength=64"
      ]
    },
    {
      "label": "single-chunk-entry-write-compact",
      "include": "org.hestiastore.benchmark.chunkentryfile.SingleChunkEntryWriterBenchmark",
      "args": [
        "-wi", "2",
        "-i", "5",
        "-f", "1",
        "-r", "2s",
        "-w", "2s",
        "-p", "entriesPerChunk=64",
        "-p", "valueLength=16"
      ]
    },
    {
      "label": "single-chunk-entry-write-large",
      "include": "org.hestiastore.benchmark.chunkentryfile.SingleChunkEntryWriterBenchmark",
      "args": [
        "-wi", "2",
        "-i", "5",
        "-f", "1",
        "-r", "2s",
        "-w", "2s",
        "-p", "entriesPerChunk=1024",
        "-p", "valueLength=64"
      ]
    }
  ]
}
